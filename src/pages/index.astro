---
import { INTERVALOS } from '../lib/eventos.js';

// Una "variable" = una pantalla dedicada. Se ordenan por ETAPA del flujo del
// comedor (de la llegada a la salida) para que el menú sea intuitivo: las
// variables aparecen en el mismo orden en que se recorre el sistema.
// `ayuda`: indicaciones de cómo/cuándo tomar ese dato (se muestran en pantalla).
// Las variables de cola se toman cada cierto tiempo (recordatorio con cuenta
// regresiva); `cadaMin` define cada cuántos minutos avisa (5 por defecto).
const ETAPAS = [
	{ titulo: '1 · Llegada', vars: [
		{ id: 'llegadas', nombre: 'Llegadas por intervalo', tipo: 'llegada',
			ayuda: 'Toca +1 por cada estudiante que entra al comedor. El intervalo de 20 min se ajusta solo a la hora; cámbialo solo si hace falta.' },
	] },
	{ titulo: '2 · Huelleros', vars: [
		{ id: 't_huellero_a', nombre: 'Tiempo huellero A', tipo: 'tiempo', estacion: 'huellero_a',
			ayuda: 'Huellero A: toca al empezar a marcar la huella de una persona y otra vez cuando termina. Repite con muchas personas.' },
		{ id: 't_huellero_b', nombre: 'Tiempo huellero B', tipo: 'tiempo', estacion: 'huellero_b',
			ayuda: 'Huellero B: toca al empezar a marcar la huella de una persona y otra vez cuando termina. Repite con muchas personas.' },
	] },
	{ titulo: '3 · Bandeja', vars: [
		{ id: 't_bandeja', nombre: 'Tiempo en bandeja', tipo: 'tiempo', estacion: 'bandeja',
			ayuda: 'Desde que la persona llega a la estación hasta que recibe su bandeja con fruta y pan.' },
	] },
	{ titulo: '4 · Línea de servido', vars: [
		{ id: 'll_linea', nombre: 'Llegadas a la línea', tipo: 'llegada', estacion: 'P1',
			ayuda: 'Toca +1 por cada persona que llega a la cola de la línea de servido (antes del P1 Postre). Se cuenta por intervalo de 20 min.' },
		{ id: 't_P1', nombre: 'P1 · Postre', tipo: 'tiempo', estacion: 'P1',
			ayuda: 'Tiempo que tarda el encargado en servir el postre a una persona. Toca al empezar y al terminar.' },
		{ id: 't_P2', nombre: 'P2 · Sopa', tipo: 'tiempo', estacion: 'P2',
			ayuda: 'Tiempo que tarda en servir la sopa a una persona. Toca al empezar y al terminar.' },
		{ id: 't_P3', nombre: 'P3 · Segundo', tipo: 'tiempo', estacion: 'P3',
			ayuda: 'Tiempo que tarda en servir el segundo a una persona. Toca al empezar y al terminar.' },
		{ id: 't_P4', nombre: 'P4 · Arroz', tipo: 'tiempo', estacion: 'P4',
			ayuda: 'Tiempo que tarda en servir el arroz a una persona. Toca al empezar y al terminar.' },
		{ id: 't_P5', nombre: 'P5 · Mate', tipo: 'tiempo', estacion: 'P5',
			ayuda: 'Tiempo que tarda en servir el mate a una persona. Toca al empezar y al terminar.' },
	] },
	{ titulo: '5 · Ají', vars: [
		{ id: 't_aji', nombre: 'Tiempo en ají', tipo: 'tiempo', estacion: 'aji',
			ayuda: 'Solo para quien se sirve ají: desde que llega a la estación hasta que termina de servirse.' },
		{ id: 'd_aji', nombre: '¿Se echa ají?', tipo: 'decision', opciones: [['aji_si', 'Sí'], ['aji_no', 'No']],
			ayuda: 'Por cada persona que pasa por el ají, marca Sí o No según se sirva o no.' },
	] },
	{ titulo: '6 · Comer', vars: [
		{ id: 'd_piso', nombre: '¿Dónde come?', tipo: 'decision', opciones: [['piso_2', '2do piso'], ['piso_1', '1er piso']],
			ayuda: 'Por cada persona que termina de servirse, marca dónde se sienta a comer: 2do o 1er piso.' },
	] },
	{ titulo: '7 · Devolución', vars: [
		{ id: 't_devolucion', nombre: 'Tiempo en devolución', tipo: 'tiempo', estacion: 'devolucion',
			ayuda: 'Desde que la persona llega al punto de devolución hasta que entrega su bandeja sucia.' },
		{ id: 'll_devolucion', nombre: 'Llegadas a devolución', tipo: 'llegada', estacion: 'devolucion',
			ayuda: 'Toca +1 por cada persona que llega al punto de devolución de bandeja. Se cuenta por intervalo de 20 min.' },
	] },
];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
		<meta name="theme-color" content="#0f172a" />
		<title>Contador · Comedor UNSAAC</title>
	</head>
	<body>
		<!-- Onboarding -->
		<div id="onboarding" class="onboarding" hidden>
			<div class="card onboarding-card">
				<h1>Toma de datos<br /><span>Comedor UNSAAC</span></h1>
				<p>¿Quién está tomando los datos?</p>
				<div class="nombres" id="nombres">
					{['Johan', 'Oscar', 'Denis', 'Brayan', 'Jose'].map((n) => (
						<button class="btn-nombre" data-nombre={n} type="button">{n}</button>
					))}
				</div>
				<div class="otro">
					<input id="nombre-input" type="text" placeholder="Otro nombre…" autocomplete="name" />
					<button id="nombre-ok" class="btn-primary">Empezar</button>
				</div>
			</div>
		</div>

		<header class="top">
			<div class="top-obs">
				<span class="dot" id="net-dot"></span>
				<span id="obs-nombre">—</span>
				<button id="cambiar-obs" class="link" type="button">cambiar</button>
			</div>
			<div class="top-sync" id="sync-badge">0 sin enviar</div>
		</header>

		<main>
			<!-- INICIO: menú de variables por etapa del flujo -->
			<section id="home" class="screen">
				{ETAPAS.map((et) => (
					<div class="grupo-menu">
						<h2 class="grupo-tit">{et.titulo}</h2>
						<div class="menu">
							{et.vars.map((v) => (
								<button
									class="var-card"
									data-id={v.id}
									data-tipo={v.tipo}
									data-nombre={v.nombre}
									data-estacion={v.estacion || ''}
									data-opciones={v.opciones ? JSON.stringify(v.opciones) : ''}
									data-ayuda={v.ayuda || ''}
									data-cada={v.cadaMin || ''}
									type="button"
								>{v.nombre}</button>
							))}
						</div>
					</div>
				))}
			</section>

			<!-- PANTALLA de una variable -->
			<section id="pantalla" class="screen" hidden>
				<div class="volver-bar">
					<button id="volver" class="volver" type="button">‹ Volver</button>
					<span id="pantalla-tit"></span>
				</div>

				<div class="indicaciones"><span class="ind-icon">ℹ</span><span id="indicaciones"></span></div>

				<!-- panel: tiempo -->
				<div data-panel="tiempo" hidden>
					<button id="crono-area" class="crono-area" type="button">
						<div class="crono-estado" id="crono-estado">Toca para iniciar</div>
						<div class="timer" id="crono-display">0.0<small>s</small></div>
					</button>
					<button id="crono-undo" class="btn-secondary" type="button" disabled>Deshacer última</button>
					<div class="stats" id="crono-stats"></div>
					<ul class="recientes" id="crono-recientes"></ul>
				</div>

				<!-- panel: llegada -->
				<div data-panel="llegada" hidden>
					<div class="reloj" id="reloj">--:--</div>
					<label class="campo">
						Intervalo (sigue el reloj; puedes cambiarlo)
						<select id="intervalo-sel">
							{INTERVALOS.map((iv) => (<option value={iv}>{iv}</option>))}
						</select>
					</label>
					<div class="contador-grande" id="llegadas-count">0</div>
					<div class="hint center">llegadas en este intervalo</div>
					<button id="llegadas-mas" class="btn-huge tap" type="button">+1 llegada</button>
					<button id="llegadas-undo" class="btn-secondary" type="button" disabled>Deshacer última</button>
				</div>

				<!-- panel: cola -->
				<div data-panel="cola" hidden>
					<div class="recordatorio" id="cola-recordatorio">
						<div class="rec-linea">Próxima lectura en <b id="cola-countdown">5:00</b></div>
						<div class="rec-ctrls">
							<label>cada
								<select id="cola-cada">
									<option value="1">1</option>
									<option value="2" selected>2</option>
									<option value="5">5</option>
								</select> min
							</label>
							<button id="cola-toggle" type="button">Pausar</button>
						</div>
					</div>
					<div class="stepper">
						<button id="cola-menos" class="step" type="button">−</button>
						<div class="step-num" id="cola-num">0</div>
						<button id="cola-mas" class="step" type="button">+</button>
					</div>
					<button id="cola-guardar" class="btn-huge" type="button">Guardar observación</button>
					<button id="cola-undo" class="btn-secondary" type="button" disabled>Deshacer última</button>
					<div class="stats" id="cola-stats"></div>
				</div>

				<!-- panel: decisión -->
				<div data-panel="decision" hidden>
					<h3 id="dec-q"></h3>
					<div class="par">
						<button class="btn-dec si" id="dec-a" type="button">
							<span id="dec-a-l"></span><b id="dec-a-n">0</b><small id="dec-a-p">0%</small>
						</button>
						<button class="btn-dec no" id="dec-b" type="button">
							<span id="dec-b-l"></span><b id="dec-b-n">0</b><small id="dec-b-p">0%</small>
						</button>
					</div>
					<div class="stats" id="dec-stats">Sin registros aún.</div>
					<button id="dec-undo" class="btn-secondary" type="button" disabled>Deshacer última</button>
				</div>
			</section>
		</main>

		<div id="toast" class="toast" hidden></div>

		<script>
			import { alCambiar, getObservador, setObservador, encolar, quitarUltimo, iniciarSync } from '../lib/cola-cliente.js';
			import { intervaloDe } from '../lib/eventos.js';

			const $ = (s) => document.querySelector(s);
			const toast = (msg) => {
				const t = $('#toast');
				t.textContent = msg; t.hidden = false;
				clearTimeout(t._t); t._t = setTimeout(() => (t.hidden = true), 1600);
			};
			const buzz = (ms = 8) => { if (navigator.vibrate) navigator.vibrate(ms); };

			// ---- Observador / onboarding ----
			function pintarObs() { $('#obs-nombre').textContent = getObservador() || '—'; }
			function pedirNombre(forzar) {
				const ob = $('#onboarding');
				if (!forzar && getObservador()) { ob.hidden = true; return; }
				const actual = getObservador();
				let preset = false;
				document.querySelectorAll('#nombres .btn-nombre').forEach((b) => {
					const on = b.dataset.nombre === actual;
					b.classList.toggle('on', on);
					if (on) preset = true;
				});
				$('#nombre-input').value = preset ? '' : actual;
				ob.hidden = false;
			}
			function elegir(nombre) { setObservador(nombre); pintarObs(); $('#onboarding').hidden = true; }
			document.querySelectorAll('#nombres .btn-nombre').forEach((b) =>
				b.addEventListener('click', () => elegir(b.dataset.nombre)));
			$('#nombre-ok').addEventListener('click', () => {
				const v = $('#nombre-input').value.trim();
				if (!v) { $('#nombre-input').focus(); return; }
				elegir(v);
			});
			$('#nombre-input').addEventListener('keydown', (e) => { if (e.key === 'Enter') $('#nombre-ok').click(); });
			$('#cambiar-obs').addEventListener('click', () => pedirNombre(true));

			// ---- Estado de red + sync badge ----
			function pintarRed() { $('#net-dot').classList.toggle('off', !navigator.onLine); }
			window.addEventListener('online', pintarRed);
			window.addEventListener('offline', pintarRed);
			alCambiar((n) => {
				$('#sync-badge').textContent = n === 0 ? 'todo enviado ✓' : `${n} sin enviar`;
				$('#sync-badge').classList.toggle('pend', n > 0);
			});

			// ---- Navegación: home <-> pantalla de variable ----
			let cur = null, relojTimer = 0, colaTimer = 0;
			function abrir(cfg) {
				cur = cfg;
				clearInterval(relojTimer); clearInterval(colaTimer);
				$('#pantalla-tit').textContent = cfg.nombre;
				$('#indicaciones').textContent = cfg.ayuda || '';
				document.querySelectorAll('#pantalla [data-panel]').forEach((p) => (p.hidden = p.dataset.panel !== cfg.tipo));
				if (cfg.tipo === 'tiempo') prepTiempo();
				else if (cfg.tipo === 'llegada') prepLlegada();
				else if (cfg.tipo === 'cola') prepCola();
				else if (cfg.tipo === 'decision') prepDecision();
				$('#home').hidden = true; $('#pantalla').hidden = false;
				window.scrollTo(0, 0);
			}
			function volver() {
				if (corriendo) { corriendo = false; cancelAnimationFrame(raf); }
				clearInterval(relojTimer); clearInterval(colaTimer);
				$('#pantalla').hidden = true; $('#home').hidden = false;
				cur = null;
			}
			$('#volver').addEventListener('click', volver);
			document.querySelectorAll('.var-card').forEach((c) =>
				c.addEventListener('click', () => abrir({
					id: c.dataset.id, tipo: c.dataset.tipo, nombre: c.dataset.nombre,
					estacion: c.dataset.estacion || null,
					opciones: c.dataset.opciones ? JSON.parse(c.dataset.opciones) : null,
					ayuda: c.dataset.ayuda || '',
					cadaMin: c.dataset.cada ? Number(c.dataset.cada) : 5,
				})));

			// ---- Tiempo (cronómetro: toca para iniciar/detener) ----
			let t0 = 0, corriendo = false, raf = 0;
			const muestras = {};
			function tick() {
				const s = (performance.now() - t0) / 1000;
				$('#crono-display').innerHTML = `${s.toFixed(1)}<small>s</small>`;
				raf = requestAnimationFrame(tick);
			}
			function statsTiempo() {
				const arr = muestras[cur.estacion] || [];
				if (arr.length) {
					const prom = arr.reduce((a, b) => a + b, 0) / arr.length;
					$('#crono-stats').textContent = `${arr.length} toma(s) · promedio ${prom.toFixed(1)} s · última ${arr[arr.length - 1].toFixed(1)} s`;
				} else {
					$('#crono-stats').textContent = 'Aún no hay tomas en esta variable.';
				}
				$('#crono-recientes').innerHTML = arr.slice(-6).reverse().map((v) => `<li>${v.toFixed(1)} s</li>`).join('');
				$('#crono-undo').disabled = arr.length === 0;
			}
			function prepTiempo() {
				corriendo = false; cancelAnimationFrame(raf);
				$('#crono-display').innerHTML = '0.0<small>s</small>';
				$('#crono-estado').textContent = 'Toca para iniciar';
				$('#crono-area').classList.remove('run');
				statsTiempo();
			}
			$('#crono-area').addEventListener('click', () => {
				if (!corriendo) {
					corriendo = true; t0 = performance.now();
					$('#crono-estado').textContent = 'Atendiendo… toca para detener';
					$('#crono-area').classList.add('run'); buzz(); tick();
				} else {
					corriendo = false; cancelAnimationFrame(raf);
					const s = Math.round(((performance.now() - t0) / 1000) * 10) / 10;
					$('#crono-area').classList.remove('run');
					$('#crono-estado').textContent = 'Toca para iniciar';
					$('#crono-display').innerHTML = '0.0<small>s</small>';
					(muestras[cur.estacion] ||= []).push(s);
					encolar({ tipo: 'tiempo', estacion: cur.estacion, valor: s });
					statsTiempo(); toast(`✓ ${s.toFixed(1)} s guardado`); buzz(12);
				}
			});
			$('#crono-undo').addEventListener('click', () => {
				const arr = muestras[cur.estacion] || [];
				if (!arr.length) return;
				const ok = quitarUltimo((ev) => ev.tipo === 'tiempo' && ev.estacion === cur.estacion);
				if (!ok) { toast('Ya se envió, no se puede deshacer'); return; }
				arr.pop(); statsTiempo(); toast('Última toma deshecha');
			});

			// ---- Llegadas ----
			const llegadasSesion = {};
			const ivSel = $('#intervalo-sel');
			// Cuenta por estación + intervalo: la entrada, la línea (P1) y la
			// devolución son pantallas distintas y no deben mezclar sus conteos.
			function estLleg() { return (cur && cur.estacion) || 'entrada'; }
			function claveLleg(iv) { return `${estLleg()}|${iv}`; }
			function pintarReloj() {
				$('#reloj').textContent = new Date().toLocaleTimeString('es-PE', { hour: '2-digit', minute: '2-digit' });
			}
			function pintarLlegadas() {
				const n = llegadasSesion[claveLleg(ivSel.value)] || 0;
				$('#llegadas-count').textContent = n;
				$('#llegadas-undo').disabled = n === 0;
			}
			function prepLlegada() {
				const iv = intervaloDe();
				ivSel.value = iv || ivSel.value || ivSel.options[0].value;
				pintarReloj(); pintarLlegadas();
				clearInterval(relojTimer); relojTimer = setInterval(pintarReloj, 1000);
			}
			ivSel.addEventListener('change', pintarLlegadas);
			$('#llegadas-mas').addEventListener('click', () => {
				const iv = ivSel.value, k = claveLleg(iv);
				llegadasSesion[k] = (llegadasSesion[k] || 0) + 1;
				pintarLlegadas(); encolar({ tipo: 'llegada', estacion: cur.estacion || undefined, valor: 1, intervalo: iv }); buzz();
			});
			$('#llegadas-undo').addEventListener('click', () => {
				const iv = ivSel.value, k = claveLleg(iv), est = estLleg();
				if (!(llegadasSesion[k] > 0)) { toast('Nada que deshacer'); return; }
				const ok = quitarUltimo((ev) => ev.tipo === 'llegada' && ev.intervalo === iv && (ev.estacion || 'entrada') === est);
				if (!ok) { toast('Ya se envió, no se puede deshacer'); return; }
				llegadasSesion[k]--; pintarLlegadas(); toast('Deshecho');
			});

			// ---- Colas (stepper + recordatorio con cuenta regresiva) ----
			let colaVal = 0, colaCadaSeg = 300, colaRestante = 300, colaPausado = false;
			function pintarCola() {
				$('#cola-num').textContent = colaVal;
				$('#cola-menos').disabled = colaVal <= 0;
			}
			function mmss(s) { return `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`; }
			function pintarCuenta() { $('#cola-countdown').textContent = mmss(Math.max(0, colaRestante)); }
			function reiniciarCuenta() { colaRestante = colaCadaSeg; pintarCuenta(); }
			function tickCola() {
				if (colaPausado) return;
				colaRestante--;
				if (colaRestante <= 0) {
					buzz([250, 120, 250]); toast('⏰ ¡Toma la cola ahora!');
					$('#cola-recordatorio').classList.add('alarma');
					setTimeout(() => $('#cola-recordatorio').classList.remove('alarma'), 4000);
					colaRestante = colaCadaSeg;
				}
				pintarCuenta();
			}
			function prepCola() {
				colaVal = 0; pintarCola();
				$('#cola-stats').textContent = ''; $('#cola-undo').disabled = true;
				colaCadaSeg = (cur.cadaMin || 5) * 60;
				$('#cola-cada').value = String(cur.cadaMin || 5);
				colaPausado = false; $('#cola-toggle').textContent = 'Pausar';
				reiniciarCuenta();
				clearInterval(colaTimer); colaTimer = setInterval(tickCola, 1000);
			}
			$('#cola-mas').addEventListener('click', () => { colaVal++; pintarCola(); buzz(); });
			$('#cola-menos').addEventListener('click', () => { if (colaVal > 0) colaVal--; pintarCola(); buzz(); });
			$('#cola-cada').addEventListener('change', (e) => { colaCadaSeg = Number(e.target.value) * 60; reiniciarCuenta(); });
			$('#cola-toggle').addEventListener('click', () => {
				colaPausado = !colaPausado;
				$('#cola-toggle').textContent = colaPausado ? 'Reanudar' : 'Pausar';
			});
			$('#cola-guardar').addEventListener('click', () => {
				encolar({ tipo: 'cola', estacion: cur.estacion, valor: colaVal });
				$('#cola-stats').textContent = `Última: ${colaVal} en cola (${new Date().toLocaleTimeString('es-PE')})`;
				$('#cola-undo').disabled = false;
				reiniciarCuenta(); // reinicia el ciclo desde la lectura recién tomada
				toast(`✓ ${colaVal} en cola guardado`); buzz(12);
			});
			$('#cola-undo').addEventListener('click', () => {
				const ok = quitarUltimo((ev) => ev.tipo === 'cola' && ev.estacion === cur.estacion);
				if (!ok) { toast('Ya se envió, no se puede deshacer'); return; }
				$('#cola-stats').textContent = 'Última observación deshecha';
				$('#cola-undo').disabled = true; toast('Deshecho');
			});

			// ---- Decisiones (con % en vivo) ----
			const decSesion = {};
			function pintarDecision() {
				const a = decSesion[cur._va] || 0, b = decSesion[cur._vb] || 0, tot = a + b;
				$('#dec-a-n').textContent = a; $('#dec-b-n').textContent = b;
				$('#dec-a-p').textContent = tot ? Math.round((a / tot) * 100) + '%' : '0%';
				$('#dec-b-p').textContent = tot ? Math.round((b / tot) * 100) + '%' : '0%';
				$('#dec-stats').textContent = tot ? `${tot} registrada(s)` : 'Sin registros aún.';
				$('#dec-undo').disabled = !cur._last;
			}
			function prepDecision() {
				const [[va, la], [vb, lb]] = cur.opciones;
				cur._va = va; cur._vb = vb; cur._last = null;
				$('#dec-q').textContent = cur.nombre;
				$('#dec-a').dataset.dec = va; $('#dec-a-l').textContent = la;
				$('#dec-b').dataset.dec = vb; $('#dec-b-l').textContent = lb;
				pintarDecision();
			}
			['#dec-a', '#dec-b'].forEach((sel) => $(sel).addEventListener('click', (e) => {
				const d = e.currentTarget.dataset.dec;
				decSesion[d] = (decSesion[d] || 0) + 1; cur._last = d;
				pintarDecision(); encolar({ tipo: 'decision', valor: d }); buzz();
			}));
			$('#dec-undo').addEventListener('click', () => {
				if (!cur._last) return;
				const ok = quitarUltimo((ev) => ev.tipo === 'decision' && ev.valor === cur._last);
				if (!ok) { toast('Ya se envió, no se puede deshacer'); return; }
				decSesion[cur._last] = Math.max(0, (decSesion[cur._last] || 0) - 1);
				cur._last = null; pintarDecision(); toast('Deshecho');
			});

			// ---- Arranque ----
			pintarObs(); pintarRed(); pedirNombre(false); iniciarSync();
		</script>

		<style>
