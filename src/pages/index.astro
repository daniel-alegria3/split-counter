---
import { ESTACIONES, INTERVALOS } from '../lib/eventos.js';

// Una "variable" = una pantalla dedicada. Se agrupan en el menú de inicio.
const tiempos = ESTACIONES.map((e) => ({
	id: 't_' + e.id, grupo: 'Tiempos de servicio', nombre: e.nombre, tipo: 'tiempo', estacion: e.id,
}));
const llegadas = [
	{ id: 'llegadas', grupo: 'Llegadas', nombre: 'Llegadas por intervalo', tipo: 'llegada' },
];
const colas = [
	{ id: 'c_huellero', nombre: 'Cola en huelleros', estacion: 'huellero' },
	{ id: 'c_linea', nombre: 'Cola en línea de servido', estacion: 'P1' },
	{ id: 'c_devolucion', nombre: 'Cola en devolución', estacion: 'devolucion' },
].map((c) => ({ ...c, grupo: 'Colas', tipo: 'cola' }));
const decisiones = [
	{ id: 'd_aji', grupo: 'Decisiones', nombre: '¿Se echa ají?', tipo: 'decision', opciones: [['aji_si', 'Sí'], ['aji_no', 'No']] },
	{ id: 'd_piso', grupo: 'Decisiones', nombre: '¿Dónde come?', tipo: 'decision', opciones: [['piso_2', '2do piso'], ['piso_1', '1er piso']] },
];

const VARIABLES = [...tiempos, ...llegadas, ...colas, ...decisiones];
const GRUPOS = ['Tiempos de servicio', 'Llegadas', 'Colas', 'Decisiones'];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
		<meta name="theme-color" content="#0f172a" />
		<title>Contador · Comedor UNSAAC</title>
	</head>
	<body>
		<!-- Onboarding -->
		<div id="onboarding" class="onboarding" hidden>
			<div class="card onboarding-card">
				<h1>Toma de datos<br /><span>Comedor UNSAAC</span></h1>
				<p>¿Quién está tomando los datos?</p>
				<div class="nombres" id="nombres">
					{['Johan', 'Oscar', 'Denis', 'Brayan', 'Jose'].map((n) => (
						<button class="btn-nombre" data-nombre={n} type="button">{n}</button>
					))}
				</div>
				<div class="otro">
					<input id="nombre-input" type="text" placeholder="Otro nombre…" autocomplete="name" />
					<button id="nombre-ok" class="btn-primary">Empezar</button>
				</div>
			</div>
		</div>

		<header class="top">
			<div class="top-obs">
				<span class="dot" id="net-dot"></span>
				<span id="obs-nombre">—</span>
				<button id="cambiar-obs" class="link" type="button">cambiar</button>
			</div>
			<div class="top-sync" id="sync-badge">0 sin enviar</div>
		</header>

		<main>
			<!-- INICIO: menú de variables -->
			<section id="home" class="screen">
				{GRUPOS.map((g) => (
					<div class="grupo-menu">
						<h2 class="grupo-tit">{g}</h2>
						<div class="menu">
							{VARIABLES.filter((v) => v.grupo === g).map((v) => (
								<button
									class="var-card"
									data-id={v.id}
									data-tipo={v.tipo}
									data-nombre={v.nombre}
									data-estacion={v.estacion || ''}
									data-opciones={v.opciones ? JSON.stringify(v.opciones) : ''}
									type="button"
								>{v.nombre}</button>
							))}
						</div>
					</div>
				))}
			</section>

			<!-- PANTALLA de una variable -->
			<section id="pantalla" class="screen" hidden>
				<div class="volver-bar">
					<button id="volver" class="volver" type="button">‹ Volver</button>
					<span id="pantalla-tit"></span>
				</div>

				<!-- panel: tiempo -->
				<div data-panel="tiempo" hidden>
					<p class="hint">Inicia y detén al terminar el servicio. Cada toma se guarda sola.</p>
					<div class="timer-wrap">
						<div class="timer" id="crono-display">0.0<small>s</small></div>
						<button id="crono-btn" class="btn-huge" type="button">Iniciar</button>
					</div>
					<div class="stats" id="crono-stats"></div>
					<ul class="recientes" id="crono-recientes"></ul>
				</div>

				<!-- panel: llegada -->
				<div data-panel="llegada" hidden>
					<p class="hint">Cada toque cuenta un estudiante que llega, en el intervalo seleccionado.</p>
					<label class="campo">
						Intervalo de 20 min
						<select id="intervalo-sel">
							{INTERVALOS.map((iv) => (<option value={iv}>{iv}</option>))}
						</select>
					</label>
					<div class="contador-grande" id="llegadas-count">0</div>
					<div class="hint center">en este intervalo (esta sesión)</div>
					<button id="llegadas-mas" class="btn-huge tap" type="button">+1 llegada</button>
					<button id="llegadas-undo" class="btn-secondary" type="button">Deshacer último</button>
				</div>

				<!-- panel: cola -->
				<div data-panel="cola" hidden>
					<p class="hint">Anota cuántas personas hay en cola en este momento.</p>
					<label class="campo">
						Personas en cola
						<input id="cola-num" type="number" inputmode="numeric" min="0" step="1" value="5" />
					</label>
					<button id="cola-guardar" class="btn-huge" type="button">Guardar observación</button>
					<div class="stats" id="cola-stats"></div>
				</div>

				<!-- panel: decisión -->
				<div data-panel="decision" hidden>
					<p class="hint">Un toque = una persona.</p>
					<h3 id="dec-q"></h3>
					<div class="par">
						<button class="btn-dec si" id="dec-a" type="button"><span id="dec-a-l"></span> <b id="dec-a-n">0</b></button>
						<button class="btn-dec no" id="dec-b" type="button"><span id="dec-b-l"></span> <b id="dec-b-n">0</b></button>
					</div>
				</div>
			</section>
		</main>

		<div id="toast" class="toast" hidden></div>

		<script>
			import { alCambiar, getObservador, setObservador, encolar, iniciarSync } from '../lib/cola-cliente.js';
			import { intervaloDe } from '../lib/eventos.js';

			const $ = (s) => document.querySelector(s);
			const toast = (msg) => {
				const t = $('#toast');
				t.textContent = msg; t.hidden = false;
				clearTimeout(t._t); t._t = setTimeout(() => (t.hidden = true), 1600);
			};

			// ---- Observador / onboarding ----
			function pintarObs() { $('#obs-nombre').textContent = getObservador() || '—'; }
			function pedirNombre(forzar) {
				const ob = $('#onboarding');
				if (!forzar && getObservador()) { ob.hidden = true; return; }
				const actual = getObservador();
				let preset = false;
				document.querySelectorAll('#nombres .btn-nombre').forEach((b) => {
					const on = b.dataset.nombre === actual;
					b.classList.toggle('on', on);
					if (on) preset = true;
				});
				$('#nombre-input').value = preset ? '' : actual;
				ob.hidden = false;
			}
			function elegir(nombre) { setObservador(nombre); pintarObs(); $('#onboarding').hidden = true; }
			document.querySelectorAll('#nombres .btn-nombre').forEach((b) =>
				b.addEventListener('click', () => elegir(b.dataset.nombre)));
			$('#nombre-ok').addEventListener('click', () => {
				const v = $('#nombre-input').value.trim();
				if (!v) { $('#nombre-input').focus(); return; }
				elegir(v);
			});
			$('#nombre-input').addEventListener('keydown', (e) => { if (e.key === 'Enter') $('#nombre-ok').click(); });
			$('#cambiar-obs').addEventListener('click', () => pedirNombre(true));

			// ---- Estado de red + sync badge ----
			function pintarRed() { $('#net-dot').classList.toggle('off', !navigator.onLine); }
			window.addEventListener('online', pintarRed);
			window.addEventListener('offline', pintarRed);
			alCambiar((n) => {
				$('#sync-badge').textContent = n === 0 ? 'todo enviado ✓' : `${n} sin enviar`;
				$('#sync-badge').classList.toggle('pend', n > 0);
			});

			// ---- Navegación: home <-> pantalla de variable ----
			let cur = null;
			function abrir(cfg) {
				cur = cfg;
				$('#pantalla-tit').textContent = cfg.nombre;
				document.querySelectorAll('#pantalla [data-panel]').forEach((p) => (p.hidden = p.dataset.panel !== cfg.tipo));
				if (cfg.tipo === 'tiempo') prepTiempo();
				else if (cfg.tipo === 'llegada') prepLlegada();
				else if (cfg.tipo === 'cola') prepCola();
				else if (cfg.tipo === 'decision') prepDecision();
				$('#home').hidden = true; $('#pantalla').hidden = false;
				window.scrollTo(0, 0);
			}
			function volver() {
				if (corriendo) { corriendo = false; cancelAnimationFrame(raf); }
				$('#pantalla').hidden = true; $('#home').hidden = false;
				cur = null;
			}
			$('#volver').addEventListener('click', volver);
			document.querySelectorAll('.var-card').forEach((c) =>
				c.addEventListener('click', () => abrir({
					id: c.dataset.id, tipo: c.dataset.tipo, nombre: c.dataset.nombre,
					estacion: c.dataset.estacion || null,
					opciones: c.dataset.opciones ? JSON.parse(c.dataset.opciones) : null,
				})));

			// ---- Tiempo ----
			let t0 = 0, corriendo = false, raf = 0;
			const muestras = {};
			function tick() {
				const s = (performance.now() - t0) / 1000;
				$('#crono-display').innerHTML = `${s.toFixed(1)}<small>s</small>`;
				raf = requestAnimationFrame(tick);
			}
			function statsTiempo() {
				const arr = muestras[cur.estacion] || [];
				$('#crono-stats').textContent = arr.length
					? `${arr.length} toma(s) · promedio ${(arr.reduce((a, b) => a + b, 0) / arr.length).toFixed(1)} s`
					: 'Sin tomas aún en esta variable.';
				$('#crono-recientes').innerHTML = arr.slice(-6).reverse().map((v) => `<li>${v.toFixed(1)} s</li>`).join('');
			}
			function prepTiempo() {
				corriendo = false; cancelAnimationFrame(raf);
				$('#crono-display').innerHTML = '0.0<small>s</small>';
				const b = $('#crono-btn'); b.textContent = 'Iniciar'; b.classList.remove('stop');
				statsTiempo();
			}
			$('#crono-btn').addEventListener('click', () => {
				const b = $('#crono-btn');
				if (!corriendo) {
					corriendo = true; t0 = performance.now();
					b.textContent = 'Detener'; b.classList.add('stop'); tick();
				} else {
					corriendo = false; cancelAnimationFrame(raf);
					const s = (performance.now() - t0) / 1000;
					b.textContent = 'Iniciar'; b.classList.remove('stop');
					(muestras[cur.estacion] ||= []).push(s);
					encolar({ tipo: 'tiempo', estacion: cur.estacion, valor: Math.round(s * 10) / 10 });
					statsTiempo(); toast(`Guardado: ${s.toFixed(1)} s`);
				}
			});

			// ---- Llegadas ----
			const llegadasSesion = {};
			const ivSel = $('#intervalo-sel');
			function pintarLlegadas() { $('#llegadas-count').textContent = llegadasSesion[ivSel.value] || 0; }
			function prepLlegada() { if (!ivSel.value) ivSel.value = intervaloDe() || ivSel.options[0].value; pintarLlegadas(); }
			ivSel.addEventListener('change', pintarLlegadas);
			$('#llegadas-mas').addEventListener('click', () => {
				const iv = ivSel.value;
				llegadasSesion[iv] = (llegadasSesion[iv] || 0) + 1;
				pintarLlegadas();
				encolar({ tipo: 'llegada', valor: 1, intervalo: iv });
				if (navigator.vibrate) navigator.vibrate(8);
			});
			$('#llegadas-undo').addEventListener('click', () => {
				const iv = ivSel.value;
				if (!llegadasSesion[iv]) { toast('Nada que deshacer'); return; }
				llegadasSesion[iv]--; pintarLlegadas();
				encolar({ tipo: 'llegada', valor: 0, intervalo: iv, notas: 'deshacer (-1)' });
				toast('Deshecho');
			});

			// ---- Colas ----
			function prepCola() { $('#cola-stats').textContent = ''; }
			$('#cola-guardar').addEventListener('click', () => {
				const n = Number($('#cola-num').value);
				if (!Number.isFinite(n) || n < 0) { toast('Número inválido'); return; }
				encolar({ tipo: 'cola', estacion: cur.estacion, valor: n });
				$('#cola-stats').textContent = `Última: ${n} (${new Date().toLocaleTimeString('es-PE')})`;
				toast('Cola registrada');
			});

			// ---- Decisiones ----
			const decSesion = {};
			function prepDecision() {
				const [[va, la], [vb, lb]] = cur.opciones;
				$('#dec-q').textContent = cur.nombre;
				$('#dec-a').dataset.dec = va; $('#dec-a-l').textContent = la; $('#dec-a-n').textContent = decSesion[va] || 0;
				$('#dec-b').dataset.dec = vb; $('#dec-b-l').textContent = lb; $('#dec-b-n').textContent = decSesion[vb] || 0;
			}
			['#dec-a', '#dec-b'].forEach((sel) => {
				$(sel).addEventListener('click', (e) => {
					const btn = e.currentTarget, d = btn.dataset.dec;
					decSesion[d] = (decSesion[d] || 0) + 1;
					btn.querySelector('b').textContent = decSesion[d];
					encolar({ tipo: 'decision', valor: d });
					if (navigator.vibrate) navigator.vibrate(8);
				});
			});

			// ---- Arranque ----
			pintarObs(); pintarRed(); pedirNombre(false); iniciarSync();
		</script>

		<style>
			* { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
			[hidden] { display: none !important; }
			:root {
				--bg: #0f172a; --panel: #1e293b; --panel2: #334155;
				--txt: #e2e8f0; --muted: #94a3b8; --accent: #38bdf8;
				--ok: #22c55e; --warn: #f59e0b; --stop: #ef4444;
			}
			html, body { margin: 0; }
			body {
				font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
				background: var(--bg); color: var(--txt);
				padding-bottom: 2rem; min-height: 100vh;
			}
			h2 { font-size: 1.15rem; margin: 0; }
			h3 { font-size: 1rem; margin: 0 0 .6rem; color: var(--txt); font-weight: 700; text-align: center; }
			.hint { color: var(--muted); font-size: .82rem; margin: 0 0 1rem; line-height: 1.4; }
			.hint.center { text-align: center; }

			.top {
				position: sticky; top: 0; z-index: 5;
				display: flex; justify-content: space-between; align-items: center;
				padding: .6rem .9rem; background: var(--panel); border-bottom: 1px solid #0008;
			}
			.top-obs { display: flex; align-items: center; gap: .5rem; font-size: .9rem; font-weight: 600; }
			.dot { width: 9px; height: 9px; border-radius: 50%; background: var(--ok); }
			.dot.off { background: var(--stop); }
			.link { background: none; border: none; color: var(--accent); font-size: .78rem; cursor: pointer; padding: 0; }
			.top-sync { font-size: .75rem; color: var(--muted); }
			.top-sync.pend { color: var(--warn); }

			main { padding: 1rem .9rem; max-width: 560px; margin: 0 auto; }

			/* Menú de inicio */
			.grupo-menu { margin-bottom: 1.4rem; }
			.grupo-tit { font-size: .8rem; text-transform: uppercase; letter-spacing: .05em; color: var(--accent); margin-bottom: .55rem; }
			.menu { display: grid; grid-template-columns: 1fr 1fr; gap: .55rem; }
			.var-card {
				background: var(--panel); color: var(--txt); border: 1px solid var(--panel2);
				border-radius: 14px; padding: 1.05rem .7rem; font-size: .95rem; font-weight: 600;
				text-align: left; cursor: pointer; min-height: 58px; line-height: 1.2;
			}
			.var-card:active { background: var(--panel2); }

			/* Pantalla de variable */
			.volver-bar { display: flex; align-items: center; gap: .6rem; margin-bottom: .8rem; }
			.volver { background: var(--panel); border: 1px solid var(--panel2); color: var(--txt); border-radius: 10px; padding: .5rem .8rem; font-size: .9rem; font-weight: 600; cursor: pointer; }
			#pantalla-tit { font-size: 1.15rem; font-weight: 700; }

			.timer-wrap { text-align: center; margin: 1rem 0; }
			.timer { font-size: 3.6rem; font-weight: 800; font-variant-numeric: tabular-nums; letter-spacing: -1px; }
			.timer small { font-size: 1.2rem; color: var(--muted); margin-left: .2rem; }

			.btn-huge {
				display: block; width: 100%; border: none; border-radius: 16px;
				background: var(--accent); color: #04293a; font-size: 1.4rem; font-weight: 800;
				padding: 1.1rem; margin-top: .8rem; cursor: pointer;
			}
			.btn-huge.stop { background: var(--stop); color: #fff; }
			.btn-huge.tap:active { transform: scale(.98); }
			.btn-primary { width: 100%; border: none; border-radius: 12px; background: var(--accent); color: #04293a; font-weight: 700; padding: .9rem; font-size: 1rem; cursor: pointer; }
			.btn-secondary { width: 100%; border: 1px solid var(--panel2); background: transparent; color: var(--muted); border-radius: 12px; padding: .8rem; margin-top: .6rem; font-size: .9rem; cursor: pointer; }

			.stats { color: var(--muted); font-size: .85rem; margin-top: .9rem; text-align: center; }
			.recientes { list-style: none; padding: 0; margin: .6rem 0 0; display: flex; flex-wrap: wrap; gap: .4rem; justify-content: center; }
			.recientes li { background: var(--panel); border-radius: 8px; padding: .25rem .55rem; font-size: .8rem; font-variant-numeric: tabular-nums; }

			.campo { display: block; color: var(--muted); font-size: .82rem; margin-bottom: 1rem; }
			.campo select, .campo input {
				display: block; width: 100%; margin-top: .35rem; padding: .8rem;
				background: var(--panel); color: var(--txt); border: 1px solid var(--panel2);
				border-radius: 12px; font-size: 1.1rem;
			}
			.contador-grande { text-align: center; font-size: 5rem; font-weight: 800; font-variant-numeric: tabular-nums; line-height: 1; margin: .5rem 0 .2rem; }

			.par { display: grid; grid-template-columns: 1fr 1fr; gap: .6rem; }
			.btn-dec {
				border: none; border-radius: 14px; padding: 1.6rem .5rem; font-size: 1.1rem; font-weight: 700;
				cursor: pointer; color: #fff; display: flex; flex-direction: column; gap: .4rem; align-items: center;
			}
			.btn-dec b { font-size: 1.6rem; }
			.btn-dec.si { background: #15803d; }
			.btn-dec.no { background: #475569; }
			.btn-dec:active { filter: brightness(1.15); }

			/* Onboarding */
			.onboarding {
				position: fixed; inset: 0; z-index: 20; background: var(--bg);
				display: flex; align-items: center; justify-content: center; padding: 1.5rem;
			}
			.onboarding-card { max-width: 360px; width: 100%; }
			.card { background: var(--panel); border-radius: 18px; padding: 1.6rem; }
			.onboarding h1 { font-size: 1.5rem; line-height: 1.15; margin: 0 0 1rem; }
			.onboarding h1 span { color: var(--accent); font-size: 1rem; font-weight: 600; }
			.onboarding p { color: var(--muted); font-size: .9rem; margin: 0 0 .8rem; }
			.nombres { display: grid; grid-template-columns: 1fr 1fr; gap: .55rem; margin-bottom: 1.1rem; }
			.btn-nombre {
				border: 1px solid var(--panel2); background: var(--bg); color: var(--txt);
				border-radius: 12px; padding: 1rem .5rem; font-size: 1.05rem; font-weight: 700; cursor: pointer;
			}
			.btn-nombre.on { background: var(--accent); color: #04293a; border-color: var(--accent); }
			.btn-nombre:active { filter: brightness(1.15); }
			.otro { display: flex; gap: .5rem; align-items: stretch; }
			.otro input { flex: 1; min-width: 0; }
			.otro .btn-primary { width: auto; white-space: nowrap; padding-left: 1.1rem; padding-right: 1.1rem; }
			.onboarding input { width: 100%; padding: .9rem; border-radius: 12px; border: 1px solid var(--panel2); background: var(--bg); color: var(--txt); font-size: 1rem; }

			.toast {
				position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); z-index: 30;
				background: #000d; color: #fff; padding: .6rem 1.1rem; border-radius: 999px; font-size: .9rem;
			}
		</style>
	</body>
</html>
